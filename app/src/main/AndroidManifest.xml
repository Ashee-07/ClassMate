<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClassMate">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.ClassMate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.RoleSelectionActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".activities.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminProfileActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminLoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.AdminDashboardActivity"
            android:exported="false" />

        <activity android:name=".activities.AssignmentsActivity" />
        <activity android:name=".activities.AnnouncementsActivity" />
        <activity android:name=".activities.ExamsActivity" />
        <activity android:name=".activities.LabsActivity" />
        <activity android:name=".activities.EventsActivity" />
        <activity android:name=".activities.SeminarsActivity" />
        <activity android:name=".activities.MaterialsActivity" />
        <activity android:name=".activities.CalendarActivity" />
        <activity android:name=".activities.DriveUpdatesActivity" />
        <activity android:name=".activities.ExamMarksActivity" />

        <activity android:name=".activities.AddAssignmentActivity" />
        <activity android:name=".activities.AddAnnouncementActivity" />
        <activity android:name=".activities.AddExamActivity" />
        <activity android:name=".activities.AddLabActivity" />
        <activity android:name=".activities.AddEventActivity" />
        <activity android:name=".activities.AddSeminarActivity" />
        <activity android:name=".activities.AddMaterialActivity" />
        <activity android:name=".activities.AddDriveUpdateActivity" />
        <activity android:name=".activities.AddExamMarkActivity" />
        <activity android:name=".activities.AddCalendarEventActivity" />

    </application>

</manifest>
